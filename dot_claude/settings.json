{
  "agentPushNotifEnabled": true,
  "autoDreamEnabled": true,
  "autoUpdatesChannel": "stable",
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "superpowers-extended-cc@superpowers-extended-cc-marketplace": true
  },
  "extraKnownMarketplaces": {
    "superpowers-extended-cc-marketplace": {
      "source": {
        "repo": "pcvelz/superpowers",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/notify.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/notify.sh",
            "type": "command"
          }
        ],
        "matcher": "AskUserQuestion"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/notify.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/notify.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "remoteControlAtStartup": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "type": "command"
  },
  "theme": "auto"
}
